{
  "entities": {
    "Material": {
      "title": "Material",
      "description": "Construction material definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "unit"]
    },
    "Scheme": {
      "title": "Scheme",
      "description": "Construction scheme definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "year": { "type": "string" },
        "materialStages": { "type": "object" }
      },
      "required": ["id", "name", "year"]
    },
    "Overseer": {
      "title": "Overseer",
      "description": "Person overseeing projects",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Panchayat": {
      "title": "Panchayat",
      "description": "Administrative unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "overseerId": { "type": "string" }
      },
      "required": ["id", "name", "overseerId"]
    },
    "Beneficiary": {
      "title": "Beneficiary",
      "description": "Support recipient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "panchayatId": { "type": "string" },
        "schemeId": { "type": "string" },
        "year": { "type": "string" }
      },
      "required": ["id", "name", "panchayatId", "schemeId", "year"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Stock receipt or issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["RECEIPT", "ISSUE"] },
        "material": { "type": "string" },
        "quantity": { "type": "number" },
        "schemeId": { "type": "string" },
        "panchayatId": { "type": "string" },
        "beneficiaryId": { "type": "string" },
        "invoiceNo": { "type": "string" },
        "invoiceUrl": { "type": "string" },
        "notes": { "type": "string" },
        "stage": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "date", "type", "material", "quantity", "schemeId", "timestamp"]
    },
    "SystemUser": {
      "title": "SystemUser",
      "description": "App user metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "role": { "type": "string", "enum": ["ADMIN", "USER"] },
        "requestedAt": { "type": "string" }
      },
      "required": ["id", "username", "status", "role", "requestedAt"]
    }
  },
  "firestore": {
    "materials": {
      "schema": "Material",
      "description": "Collection of materials"
    },
    "schemes": {
      "schema": "Scheme",
      "description": "Collection of schemes"
    },
    "overseers": {
      "schema": "Overseer",
      "description": "Collection of overseers"
    },
    "panchayats": {
      "schema": "Panchayat",
      "description": "Collection of panchayats"
    },
    "beneficiaries": {
      "schema": "Beneficiary",
      "description": "Collection of beneficiaries"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of stock transactions"
    },
    "users": {
      "schema": "SystemUser",
      "description": "Collection of system users"
    }
  }
}
