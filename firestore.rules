rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'ranjanmano11795@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isOwner() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'APPROVED');
    }

    function isApproved() {
      return isOwner() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'APPROVED');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /materials/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /schemes/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /overseers/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /panchayats/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /beneficiaries/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /transactions/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }
  }
}
